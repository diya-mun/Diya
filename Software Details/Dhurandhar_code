def build_cards(active_theme):
    parts = []
    for key, meta in THEME_META.items():
        swatch_html = ""
        for c in meta["hex"]:
            swatch_html += '<div class="swatch" style="background:' + c + '"></div>'
        colour_csv = ",".join(meta["hex"])
        active_cls = " active" if key == active_theme else ""
        card = (
            '<a href="#" class="theme-card' + active_cls + '"'
            ' data-theme="' + key + '"'
            ' data-colours="' + colour_csv + '">'
            + '<div class="card-glow"></div>'
            + '<div class="swatches">' + swatch_html + '</div>'
            + '<div class="theme-name">' + meta["title"] + '</div>'
            + '<div class="card-arrow">&#8599;</div>'
            + '</a>'
        )
        parts.append(card)
    return "".join(parts)
 
def build_preview(colours):
    return "".join(
        '<div class="preview-seg" style="background:' + c + '"></div>'
        for c in colours
    )
 
def build_json_colours(colours):
    return "[" + ",".join('"' + c + '"' for c in colours) + "]"
 

def send_all(conn, data):
    if isinstance(data, str):
        data = data.encode("utf-8")
    mv   = memoryview(data)
    sent = 0
    while sent < len(mv):
        try:
            n = conn.send(mv[sent:])
            if n:
                sent += n
        except OSError as e:
            if e.args[0] == 11:      
                time.sleep_ms(5)
            else:
                raise
 
 
