MOTOR_RUN_MS  = 10000
motor_stop_at = 0          
 
def motor_start():
    global motor_stop_at
    motor_stop_at = time.ticks_ms() + MOTOR_RUN_MS
    en.duty(850)
    IN1.value(1)
    IN2.value(0)
 
def motor_stop():
    global motor_stop_at
    motor_stop_at = 0
    en.duty(0)
    IN1.value(0)
    IN2.value(0)
 
def motor_tick():
    if motor_stop_at and time.ticks_diff(motor_stop_at, time.ticks_ms()) <= 0:
        motor_stop()
 

PEW_PATTERN = [
    (1800, 700,  60),
    (0,    0,   100),
    (1800, 700,  60),
    (0,    0,   100),
    (1800, 700,  60),
    (0,    0,   100),
    (1800, 700,  60),
    (0,    0,   100),
]
 
buzz_step   = 0
buzz_due_at = 0
buzz_active = False
 
def buzzer_start():
    global buzz_step, buzz_due_at, buzz_active
    buzz_step   = 0
    buzz_active = True
    buzz_due_at = time.ticks_ms()
 
def buzzer_tick():
    global buzz_step, buzz_due_at, buzz_active
    if not buzz_active:
        return
    if time.ticks_diff(time.ticks_ms(), buzz_due_at) < 0:
        return
    if buzz_step >= len(PEW_PATTERN):
        buzzer.duty(0)
        buzz_active = False
        return
    freq, duty, duration_ms = PEW_PATTERN[buzz_step]
    if freq:
        buzzer.freq(freq)
    buzzer.duty(duty)
    buzz_due_at = time.ticks_ms() + duration_ms
    buzz_step  += 1
 

limit_last = 1
 
def limitswitch_tick():
    global limit_last
    current = limitswitch.value()
    if limit_last == 1 and current == 0:
        print("Limit switch hit")
        buzzer_start()
    limit_last = current
 

