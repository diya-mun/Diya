server.bind(addr)
server.listen(1)
server.setblocking(False)
print("HTTP server ready.")
 

while True:
 
    buzzer_tick()
    motor_tick()
    limitswitch_tick()
 
    if pushbutton.value() == 0:
        print(pushbutton.value())
        if motor_stop_at == 0:
            print("detected — motor start")
            motor_start()
 
    conn = None
    try:
        conn, addr_client = server.accept()
        conn.settimeout(2)
        try:
            request = conn.recv(2048).decode("utf-8")
        except:
            request = ""
 
        is_ajax = False
        if "GET " in request:
            path = request.split(" ")[1].split("?")[0]
            if path.startswith("/theme/"):
                new_theme = path.split("/")[-1]
                if new_theme in THEME_META:
                    state["theme"] = new_theme
                    update_rings(new_theme)
                    print("Theme ->", new_theme)
                conn.send(b"HTTP/1.1 200 OK\r\nContent-Length: 2\r\nConnection: close\r\n\r\nOK")
                is_ajax = True
 
        if not is_ajax:
            stream_page(conn, state["theme"])
 
        conn.close()
 
    except OSError:
        pass
    except Exception as e:
        print("HTTP error:", e)
        if conn:
            try:
                conn.close()
            except:
                pass
 
    time.sleep_ms(10)
