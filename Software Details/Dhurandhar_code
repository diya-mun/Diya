def hex_to_rgb(h, brightness=0.35):
    h = h.lstrip("#")
    r = int(h[0:2], 16)
    g = int(h[2:4], 16)
    b = int(h[4:6], 16)
    return (int(r * brightness), int(g * brightness), int(b * brightness))
 
def update_rings(theme_name):
    colours     = THEME_META.get(theme_name, THEME_META["sher_e_baloch_gold"])["hex"]
    num_colours = len(colours)
    for i in range(NUM_LEDS):
        colour_idx = (i * num_colours) // NUM_LEDS
        rgb = hex_to_rgb(colours[colour_idx])
        np1[i] = rgb
        np2[i] = rgb
    np1.write()
    np2.write()
 
